<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_bar"> <!-- Reutilizamos tu fondo redondeado -->

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finalizar Pedido"
        android:textAlignment="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/tvTotalModal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Total a pagar: $0.00"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textColor="#2E7D32" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Selecciona método de pago:"
        android:textStyle="bold" />

    <!-- Opción Mercado Pago -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMercadoPago"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Mercado Pago"
        android:textAllCaps="false"
        app:icon="@android:drawable/ic_menu_send"
        app:cornerRadius="12dp" />

    <!-- Opción Efectivo -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEfectivo"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="Efectivo / Al recibir"
        android:textAllCaps="false"
        app:icon="@android:drawable/ic_menu_myplaces"
        app:cornerRadius="12dp" />

</LinearLayout>